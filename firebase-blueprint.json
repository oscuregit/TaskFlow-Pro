{
  "entities": {
    "UserSettings": {
      "title": "UserSettings",
      "description": "User preferences and settings",
      "type": "object",
      "properties": {
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "language": { "type": "string", "enum": ["tr", "en"] },
        "timezone": { "type": "string" },
        "notifications": {
          "type": "object",
          "properties": {
            "email": { "type": "boolean" },
            "push": { "type": "boolean" }
          }
        },
        "exchangeRates": {
          "type": "object",
          "properties": {
            "USD": { "type": "number" },
            "EUR": { "type": "number" },
            "GBP": { "type": "number" }
          }
        }
      },
      "required": ["theme", "language", "timezone", "notifications"]
    },
    "Client": {
      "title": "Client",
      "description": "Client information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "company": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "userId", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "Task information",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "clientId": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in_progress", "waiting", "done"] },
        "dueDate": { "type": "string" },
        "timezone": { "type": "string" },
        "difficulty": { "type": "number" },
        "estimatedHours": { "type": "number" },
        "actualHours": { "type": "number" },
        "expectedRevenue": { "type": "number" },
        "currency": { "type": "string" },
        "expenses": { "type": "array" },
        "subtasks": { "type": "array" },
        "timeline": { "type": "array" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "status", "difficulty", "userId", "createdAt"]
    },
    "GeneralExpense": {
      "title": "GeneralExpense",
      "description": "General monthly expenses not tied to a specific client/task",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["description", "amount", "date", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/settings/{userId}": {
      "schema": { "$ref": "#/entities/UserSettings" },
      "description": "User settings document where document ID is the user's UID"
    },
    "/clients/{clientId}": {
      "schema": { "$ref": "#/entities/Client" },
      "description": "Clients created by users"
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Tasks created by users"
    },
    "/generalExpenses/{expenseId}": {
      "schema": { "$ref": "#/entities/GeneralExpense" },
      "description": "General expenses created by users"
    }
  }
}
