rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: {userId}
    // Fields:
    //   - theme: string (required, 'light' or 'dark')
    //   - language: string (required, 'tr' or 'en')
    //   - timezone: string (required)
    //   - notifications: map (required)
    //   - exchangeRates: map (optional)
    //
    // Collection: clients
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - company: string (optional)
    //   - email: string (optional)
    //   - phone: string (optional)
    //   - userId: string (required, must match auth.uid)
    //   - createdAt: string (required)
    //
    // Collection: tasks
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - clientId: string (optional)
    //   - status: string (required, 'todo', 'in_progress', 'waiting', 'done')
    //   - dueDate: string (optional)
    //   - timezone: string (optional)
    //   - difficulty: number (required, 1-10)
    //   - estimatedHours: number (optional)
    //   - actualHours: number (optional)
    //   - expectedRevenue: number (optional)
    //   - currency: string (optional)
    //   - expenses: list (optional)
    //   - subtasks: list (optional)
    //   - timeline: list (optional)
    //   - userId: string (required, must match auth.uid)
    //   - createdAt: string (required)
    //
    // ===============================================================
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }
    
    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidSettings() {
      let data = request.resource.data;
      return hasRequiredFields(['theme', 'language', 'timezone', 'notifications']) &&
             data.theme in ['light', 'dark'] &&
             data.language in ['tr', 'en'] &&
             data.timezone is string && data.timezone.size() < 100 &&
             data.notifications is map &&
             (!('exchangeRates' in data) || data.exchangeRates is map);
    }
    
    function isValidClient() {
      let data = request.resource.data;
      return hasRequiredFields(['name', 'userId', 'createdAt']) &&
             validStringLength('name', 1, 100) &&
             isValidOptionalString('company', 0, 100) &&
             isValidOptionalString('email', 0, 100) &&
             isValidOptionalString('phone', 0, 50) &&
             data.userId == request.auth.uid &&
             data.createdAt is string;
    }
    
    function isValidTask() {
      let data = request.resource.data;
      return hasRequiredFields(['title', 'status', 'difficulty', 'userId', 'createdAt']) &&
             validStringLength('title', 1, 200) &&
             isValidOptionalString('description', 0, 5000) &&
             isValidOptionalString('clientId', 0, 100) &&
             data.status in ['todo', 'in_progress', 'waiting', 'done'] &&
             isValidOptionalString('dueDate', 0, 50) &&
             isValidOptionalString('timezone', 0, 100) &&
             data.difficulty is number && data.difficulty >= 1 && data.difficulty <= 10 &&
             (!('estimatedHours' in data) || data.estimatedHours is number) &&
             (!('actualHours' in data) || data.actualHours is number) &&
             (!('expectedRevenue' in data) || data.expectedRevenue is number) &&
             isValidOptionalString('currency', 0, 10) &&
             (!('expenses' in data) || data.expenses is list) &&
             (!('subtasks' in data) || data.subtasks is list) &&
             (!('timeline' in data) || data.timeline is list) &&
             data.userId == request.auth.uid &&
             data.createdAt is string;
    }

    function isValidGeneralExpense() {
      let data = request.resource.data;
      return hasRequiredFields(['description', 'amount', 'date', 'userId', 'createdAt']) &&
             validStringLength('description', 1, 500) &&
             data.amount is number &&
             isValidOptionalString('currency', 0, 10) &&
             data.date is string &&
             isValidOptionalString('category', 0, 100) &&
             (!('recurrence' in data) || data.recurrence in ['one_time', 'monthly', 'yearly']) &&
             data.userId == request.auth.uid &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSettings();
      allow update: if isOwner(userId) && isValidSettings();
      allow delete: if isOwner(userId);
    }
    
    match /clients/{clientId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidClient() && uidUnchanged();
      allow update: if isDocOwner() && isValidClient() && uidNotModified();
      allow delete: if isDocOwner();
    }
    
    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTask() && uidUnchanged();
      allow update: if isDocOwner() && isValidTask() && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /generalExpenses/{expenseId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidGeneralExpense() && uidUnchanged();
      allow update: if isDocOwner() && isValidGeneralExpense() && uidNotModified();
      allow delete: if isDocOwner();
    }
    
    // Deny access to everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
